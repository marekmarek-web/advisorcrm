{
  "name": "aidvisora",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.36.4"
    },
    "patchedDependencies": {
      "@supernotes/capacitor-send-intent@7.0.0": "patches/@supernotes__capacitor-send-intent@7.0.0.patch"
    }
  },
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.mjs",
    "build": "pnpm -r build",
    "dev": "pnpm --filter web dev",
    "dev:unlock": "pnpm --filter web dev:unlock",
    "dev:demo": "pnpm --filter web dev:demo",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter db generate",
    "db:migrate": "pnpm --filter db migrate",
    "db:apply-schema": "pnpm --filter db apply-schema",
    "db:seed-partners": "pnpm --filter db seed-partners",
    "db:seed-catalog": "pnpm --filter db seed-catalog",
    "db:catalog-diff": "pnpm --filter db catalog-diff",
    "db:push": "pnpm --filter db push",
    "db:studio": "pnpm --filter db studio",
    "seed": "pnpm --filter db seed",
    "test": "pnpm -r test",
    "test:assistant-regression": "pnpm --filter web test:assistant-regression",
    "compliance:copy-check": "node scripts/compliance-copy-check.mjs",
    "audit:tenant": "node tools/tenant-audit/audit-tenant-queries.mjs",
    "db:verify-documents-schema": "node scripts/verify-documents-schema.mjs",
    "benchmark:claude": "node --env-file=apps/web/.env.local scripts/benchmark-claude-review.mjs",
    "eval:golden-live": "pnpm --filter web eval:golden-live",
    "ai-review:batch": "pnpm --filter web ai-review:batch",
    "ai-review:batch:smoke": "pnpm --filter web ai-review:batch:smoke",
    "debug:anchors": "pnpm --filter web debug:anchors",
    "debug:anchors:core": "pnpm --filter web debug:anchors:core",
    "test:f9-release-gate": "pnpm --filter web test:f9-release-gate"
  },
  "dependencies": {
    "postgres": "^3.4.4"
  },
  "engines": {
    "node": ">=20.9"
  },
  "packageManager": "pnpm@9.0.0"
}
