{
  "name": "advisor-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter web dev",
    "dev:demo": "pnpm --filter web dev:demo",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter db generate",
    "db:migrate": "pnpm --filter db migrate",
    "db:apply-schema": "pnpm --filter db apply-schema",
    "db:seed-partners": "pnpm --filter db seed-partners",
    "db:seed-catalog": "pnpm --filter db seed-catalog",
    "db:push": "pnpm --filter db push",
    "db:studio": "pnpm --filter db studio",
    "seed": "pnpm --filter db seed",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0"
}
