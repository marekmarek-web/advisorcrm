#!/bin/sh
# Blokuje push do remote, pokud v repu existuje tenant-scope porušení,
# které není odůvodněné v tools/tenant-audit/allow-list.json.
#
# Skip: SKIP_TENANT_AUDIT=1 git push ...
# CI: běží samostatný krok v .github/workflows/ci.yml (zde přeskakujeme).

[ -n "$CI" ] && exit 0
[ -n "$SKIP_TENANT_AUDIT" ] && exit 0

if ! node tools/tenant-audit/audit-tenant-queries.mjs >/dev/null 2>&1; then
  echo "" >&2
  echo "pre-push: tenant-scope audit selhal. Spusť 'pnpm audit:tenant' pro detail." >&2
  echo "Přidej tenant guard (withAuthContext / eq(X.tenantId, ...)) nebo doplň odůvodněný záznam do tools/tenant-audit/allow-list.json." >&2
  echo "" >&2
  exit 1
fi
exit 0
