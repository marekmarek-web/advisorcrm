{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:clear-lock": "node -e \"try { require('fs').unlinkSync('.next/dev/lock'); } catch (_) {}\"",
    "dev:unlock": "pnpm dev:clear-lock && next dev --webpack",
    "dev:turbo": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next dev --webpack",
    "dev:demo": "cross-env NEXT_PUBLIC_SKIP_AUTH=true next dev --webpack",
    "build": "next build",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint . --quiet",
    "lint:report": "eslint .",
    "test": "vitest run src",
