{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:clear-lock": "node -e \"try { require('fs').unlinkSync('.next/dev/lock'); } catch (_) {}\"",
    "dev:unlock": "pnpm dev:clear-lock && next dev --webpack",
    "dev:turbo": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next dev --webpack",
    "dev:demo": "cross-env NEXT_PUBLIC_SKIP_AUTH=true next dev --webpack",
    "build": "next build",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint . --quiet",
    "lint:report": "eslint .",
    "test": "vitest run src",
    "test:assistant-regression": "vitest run src/lib/ai/__tests__/assistant-release-gate.test.ts src/lib/ai/__tests__/assistant-regression-suite.test.ts src/lib/ai/__tests__/assistant-eval-harness.test.ts src/lib/ai/__tests__/assistant-hypo-edge-cases.test.ts src/lib/ai/__tests__/assistant-product-workflows.test.ts src/lib/ai/__tests__/assistant-execution-ui.test.ts src/lib/ai/__tests__/assistant-write-contract-plan.test.ts src/lib/ai/__tests__/assistant-context-safety.test.ts src/lib/observability/__tests__/assistant-sentry.test.ts",
    "test:ai-review-phase2-regression": "vitest run src/lib/ai/__tests__/phase-2-review-regression.test.ts src/lib/ai/__tests__/legacy-insurance-proposal-envelope.test.ts src/lib/ai/__tests__/quality-gates.test.ts src/lib/calculators/investment/__tests__/investment.backtest.test.ts src/lib/observability/__tests__/assistant-sentry.test.ts",
    "test:ai-review-phase3-regression": "vitest run src/lib/ai/__tests__/phase-3-payment-sync-regression.test.ts src/lib/ai/__tests__/quality-gates.test.ts src/lib/calculators/investment/__tests__/investment.backtest.test.ts src/lib/observability/__tests__/assistant-sentry.test.ts src/lib/observability/__tests__/contract-review-sentry.test.ts",
    "test:ai-review-phase4-regression": "vitest run src/lib/ai/__tests__/phase-4-review-workbench-regression.test.ts src/lib/ai/__tests__/phase-3-payment-sync-regression.test.ts src/lib/ai/__tests__/quality-gates.test.ts src/lib/observability/__tests__/contract-review-sentry.test.ts",
    "test:client-portal-phase5-regression": "vitest run src/lib/client-portal/__tests__/phase-5-client-portal-bridge-regression.test.ts src/lib/observability/__tests__/contract-review-sentry.test.ts src/lib/observability/__tests__/assistant-sentry.test.ts src/lib/calculators/investment/__tests__/investment.backtest.test.ts",
    "test:e2e": "playwright test",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:dev": "cross-env CAPACITOR_SERVER_URL=http://localhost:3000/prihlaseni?native=1 npx cap sync",
    "cap:dev:android": "cross-env CAPACITOR_SERVER_URL=http://10.0.2.2:3000/prihlaseni?native=1 npx cap sync",
    "cap:dev:remote": "node scripts/cap-dev-remote.js",
    "cap:dev:ngrok": "node scripts/cap-dev-ngrok.js",
    "emulator:android": "node scripts/start-android-emulator.js",
    "brand:assets": "node scripts/prepare-ai-button-alpha.mjs && node scripts/generate-brand-assets.mjs",
    "cap:assets": "pnpm brand:assets && npx capacitor-assets generate && node scripts/copy-pwa-icons-to-public.mjs && node scripts/regenerate-public-pwa-webp.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/core": "^8.2.0",
    "@capacitor/push-notifications": "^8.0.2",
    "@capgo/capacitor-document-scanner": "^8.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@napi-rs/canvas": "^0.1.97",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@sentry/nextjs": "^10.45.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@supernotes/capacitor-send-intent": "^7.0.0",
    "@tanstack/react-query": "^5",
    "@tanstack/react-virtual": "^3.13.23",
    "@vercel/speed-insights": "^2.0.0",
    "apexcharts": "^5.10.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "db": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "exifr": "^7.1.3",
    "google-auth-library": "^10.6.2",
    "html-to-image": "1.11.11",
    "jszip": "^3.10.1",
    "lucide-react": "^0.454.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.27.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-apexcharts": "^2.1.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.0",
    "resend": "^4.0.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1",
    "styled-jsx": "^5.1.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.3.0",
    "vitest": "^2.1.0"
  }
}
