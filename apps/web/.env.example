# =============================================================================
# Aidvisor web — šablona prostředí (ORIGINÁL v repu)
# =============================================================================
# Lokálně: zkopírujte tento soubor → .env.local a doplňte tajné hodnoty.
#   PowerShell:  Copy-Item .env.example .env.local
#   bash:        cp .env.example .env.local
# Soubor .env.local je v .gitignore a na Git nepatří.
#
# Vercel: Project → Settings → Environment Variables — STEJNÉ názvy proměnných
#   jako zde (Production + Preview). Po změně redeploy.
#
# Rychlý import promptů: ai uceni/vercel-openai-prompts.env (názvy musí sedět).
# Kód: prompt-registry.ts (copilot), prompt-model-registry.ts (AI Review).
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Veřejný klíč: buď legacy „anon“ JWT (eyJ…), nebo nový publishable (sb_publishable_…) z API settings.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Pokud dashboard nabízí jen publishable, stačí jedna z těchto řádek (kód bere anon → default → publishable):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Produkce: kanonická URL aplikace (pro e-maily, pozvánky). Např. https://www.aidvisora.cz
NEXT_PUBLIC_APP_URL=https://www.aidvisora.cz
# Lokální vývoj (e-maily, odkazy ze serveru): http://localhost:3000 — viz docs/PLATFORM_SETUP.md

# Vypne vícestránkový sken (/portal/scan, položka v nabídce Nový). Základní nahrání v Dokumenty zůstane.
# NEXT_PUBLIC_PORTAL_SCAN_ENABLED=false

# Volitelné: staré Vercel preview domény → přesměrování na produkci (proxy). Čárkou oddělený seznam hostů.
# AIDVISORA_LEGACY_VERCEL_HOSTS=advisorcrm-web.vercel.app

# Úvodní stránka: URL embed videa (např. YouTube: https://www.youtube.com/embed/VIDEO_ID)
# NEXT_PUBLIC_LANDING_DEMO_VIDEO_URL=

# =============================================================================
# OpenAI — stejné proměnné lokálně i na Vercelu
# =============================================================================

OPENAI_API_KEY=

# Fallback model, když není nastaven specializovaný default níže.
OPENAI_MODEL=gpt-4o-mini

# Copilot / portálové shrnutí — doporučeno gpt-4.1-mini (ověřte přesný slug v OpenAI dashboardu).
OPENAI_MODEL_COPILOT_DEFAULT=gpt-4.1-mini

# AI Review (klasifikace, extrakce, review decision, client match) — doporučeno gpt-5.4-mini.
OPENAI_MODEL_AI_REVIEW_DEFAULT=gpt-5.4-mini

# Poradenský chat (pravý panel + návrh odpovědi) — výchozí dědí z OPENAI_MODEL (gpt-5-mini v kódu).
OPENAI_MODEL_ADVISOR_CHAT=gpt-5-mini

# Volitelné přepsání jen pro vybraný krok (viz apps/web/src/lib/openai.ts resolveOpenAIModel).
# OPENAI_MODEL_AI_REVIEW_CLASSIFIER=
# OPENAI_MODEL_AI_REVIEW_EXTRACTION=

# Globální verze Prompt Builder promptů (např. "1"). Nebo per-prompt *_VERSION níže.
OPENAI_PROMPT_VERSION=

# -----------------------------------------------------------------------------
# AI Review pipeline v2 — ve výchozím stavu ZAPNUTÁ. Vypnout jen pro diagnostiku:
# AI_REVIEW_USE_V2_PIPELINE=false
# Verbose AI Review (pipeline fáze, Prompt Builder kroky, OpenAI latency) — viz apps/web/src/lib/ai/ai-review-debug.ts
# AI_REVIEW_DEBUG=true
# AI_REVIEW_DEBUG_LOG=1
# AI_REVIEW_PROVIDER_DEBUG=true
# AIDVISORA_DEBUG_AI_REVIEW=1
AI_REVIEW_CLASSIFIER_CONFIDENCE_MIN=0.35
AI_REVIEW_AMENDMENT_CONFIDENCE_MIN=0.55

# -----------------------------------------------------------------------------
# Copilot — Prompt Builder (6× team / klient asistent)
# -----------------------------------------------------------------------------
OPENAI_PROMPT_CLIENT_SUMMARY_ID=
OPENAI_PROMPT_CLIENT_OPPORTUNITIES_ID=
OPENAI_PROMPT_NEXT_BEST_ACTION_ID=
OPENAI_PROMPT_PRE_MEETING_BRIEFING_ID=
OPENAI_PROMPT_POST_MEETING_FOLLOWUP_ID=
OPENAI_PROMPT_TEAM_SUMMARY_ID=

# Portál — shrnutí plateb pro poradce (stejná rodina jako copilot; env připraveno pro napojení v kódu).
OPENAI_PROMPT_PORTAL_PAYMENT_SUMMARY_ID=

# -----------------------------------------------------------------------------
# AI Review — Prompt Builder (pořadí odpovídá ai uceni/vercel-openai-prompts.env)
# Prázdné = u některých typů manual_review nebo legacy inline extrakce.
# -----------------------------------------------------------------------------
OPENAI_PROMPT_AI_REVIEW_CAR_INSURANCE_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_NON_LIFE_INSURANCE_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_BUILDING_SAVINGS_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_LEGACY_FINANCIAL_PRODUCT_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_DIP_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_RETIREMENT_PRODUCT_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_CLIENT_MATCH_ID=
OPENAI_PROMPT_AI_REVIEW_CLIENT_MATCH_VERSION=
# Shrnutí dokumentu pro poradce (Prompt Builder: document_summary_payload, review_decision_payload, client_match_payload).
OPENAI_PROMPT_AI_REVIEW_DOCUMENT_SUMMARY_FOR_ADVISOR_ID=
OPENAI_PROMPT_AI_REVIEW_DOCUMENT_SUMMARY_FOR_ADVISOR_VERSION=
OPENAI_PROMPT_AI_REVIEW_REVIEW_DECISION_ID=
OPENAI_PROMPT_AI_REVIEW_REVIEW_DECISION_VERSION=
OPENAI_PROMPT_AI_REVIEW_SUPPORTING_DOCUMENT_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_LOAN_CONTRACT_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_INVESTMENT_CONTRACT_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_PAYMENT_INSTRUCTIONS_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_INSURANCE_CONTRACT_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_DOC_CLASSIFIER_ID=
OPENAI_PROMPT_AI_REVIEW_DOC_CLASSIFIER_VERSION=
OPENAI_PROMPT_AI_REVIEW_INSURANCE_PROPOSAL_MODELATION_ID=
OPENAI_PROMPT_AI_REVIEW_INSURANCE_AMENDMENT_ID=
# Bundle: sekční extrakce (prázdné = lokální hardcoded prompt v orchestrátoru).
OPENAI_PROMPT_AI_REVIEW_HEALTH_SECTION_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_INVESTMENT_SECTION_EXTRACTION_ID=

# Doplňkové AI Review prompty (často ještě bez šablony v projektu — nechte prázdné).
OPENAI_PROMPT_AI_REVIEW_INVESTMENT_PROPOSAL_ID=
OPENAI_PROMPT_AI_REVIEW_MORTGAGE_EXTRACTION_ID=
OPENAI_PROMPT_AI_REVIEW_TERMINATION_DOCUMENT_ID=
OPENAI_PROMPT_AI_REVIEW_CONSENT_IDENTIFICATION_ID=
OPENAI_PROMPT_AI_REVIEW_CONFIRMATION_DOCUMENT_ID=

# Resend (e-mail) – get your API key at https://resend.com
# Replace re_xxxxxxxxx with your real API key from Resend dashboard
RESEND_API_KEY=re_xxxxxxxxx
# Lokálně: onboarding@resend.dev. Produkce (ověřená doména): např. noreply@aidvisora.cz nebo Aidvisora <noreply@aidvisora.cz>
RESEND_FROM_EMAIL=onboarding@resend.dev
# Volitelně: doména pro personalizovaný From (musí být ověřená v Resend), např. aidvisora.cz
# RESEND_FROM_DOMAIN=aidvisora.cz
# Volitelně: globální fallback Reply-To, pokud není e-mail v profilu / účtu
# RESEND_REPLY_TO=

# Google OAuth2 (sdílený pro Calendar, Drive, Gmail) – https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web application).
# Authorized redirect URIs:
#   http://localhost:3000/api/integrations/google-calendar/callback
#   http://localhost:3000/api/integrations/google-drive/callback
#   http://localhost:3000/api/integrations/gmail/callback
#   https://www.aidvisora.cz/api/integrations/google-calendar/callback
#   https://www.aidvisora.cz/api/integrations/google-drive/callback
#   https://www.aidvisora.cz/api/integrations/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Zpětná kompatibilita (starší kód čte tyto; nastavte na stejné hodnoty jako výše):
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Šifrování tokenů integrací (AES-256): 32 B v hex (64 znaků) nebo alespoň 32 znaků UTF-8.
# Vygenerovat např.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATIONS_ENCRYPTION_KEY=

# Google Maps / Places API – autocomplete adres.
# Vytvořte API key v Google Cloud Console s omezením na Places API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Capacitor – dev server pro mobilní build (volitelné)
# cap:dev = localhost:3000 (prohlížeč / stejný počítač)
# cap:dev:android = 10.0.2.2:3000 (lokální Android emulátor na tomto PC)
# Vzdálený telefon / cloud emulátor: použij v apps/web příkaz „pnpm cap:dev:remote“
#   (nastaví URL na IP tohoto počítače). Telefon a PC musí být ve stejné síti.
# Volitelně: další hostitelé pro Next dev (Capacitor z telefonu / LAN IP), čárkou oddělené.
# NEXT_ALLOWED_DEV_ORIGINS=192.168.0.104,192.168.1.23
#
# Cloud / vzdálené zařízení (bez přístupu do sítě): spusť ngrok (ngrok http 3000),
#   pak v apps/web: pnpm cap:dev:ngrok (načte URL z ngrok a spustí cap sync).
# CAPACITOR_SERVER_URL=http://192.168.1.100:3000

# --- POUZE LOKÁLNÍ VÝVOJ (NIKDY NEVYPLŇOVAT NA VERCELU / V PRODUKCI) ---
# NEXT_PUBLIC_SKIP_AUTH=true  → dashboard bez přihlášení (např. pnpm dev:demo)
# DEV_CONTRACTS_USER_ID=uuid  → bypass auth pro API při NODE_ENV=development (UUID z auth.users)
# Na Vercelu produkce se tyto proměnné ignorují (kód kontroluje VERCEL_ENV).
# NEXT_PUBLIC_SKIP_AUTH=false
# DEV_CONTRACTS_USER_ID=

# --- Sentry (error tracking) – https://sentry.io ---
# DSN z projektu (Next.js). Pro klienta musí být veřejná varianta:
NEXT_PUBLIC_SENTRY_DSN=
# Volitelně stejný DSN pro server (jinak se použije NEXT_PUBLIC_SENTRY_DSN):
# SENTRY_DSN=
# Volitelně: environment tag v Sentry na klientu (preview vs production); jinak NODE_ENV
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Volitelně: tracesSampleRate 0–1 (staging diagnostika; výchozí 0.1 v produkci, 1.0 v dev)
# SENTRY_TRACES_SAMPLE_RATE=0.25
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.25
# Build / CI – upload source maps (token z sentry.io → Auth tokens, scope project:releases)
# SENTRY_AUTH_TOKEN=
# Příklad (tvůj Sentry projekt): org aidvisora, project javascript-nextjs
# SENTRY_ORG=aidvisora
# SENTRY_PROJECT=javascript-nextjs

# --- Stripe (předplatné workspace) – https://dashboard.stripe.com ---
# Publishable: veřejný klíč (pk_live_… / pk_test_…). Secret a webhook secret jen na serveru.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Tarify: u každého produktu ve Stripe (Starter / Pro / Team) zkopíruj Price ID pro měsíční a roční cenu.
# Pokud jsou vyplněné, aplikace zobrazí výběr tarifu. Test/live price ID musí odpovídat režimu klíčů.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=
# Zkušební období před první fakturací (0 = vypnuto). Výchozí 14.
# STRIPE_TRIAL_PERIOD_DAYS=14
# Legacy: jedna recurring cena bez výběru tarifu (použije se jen pokud výše nemáš žádnou STRIPE_PRICE_*_*)
# STRIPE_PRICE_ID=

# --- Document Processing (Adobe PDF Services) ---
# Ovlivňuje rychlost AI review smluv: zapnutý Adobe = OCR/normalizace před GPT (lepší skeny, +sekundy až desítky s).
# Provider: "adobe" | "disabled" | "none" (default: "none"). Bez Adobe pipeline použije přímo PDF u OpenAI.
# DOCUMENT_PROCESSING_PROVIDER=none
# Master switch for document processing pipeline (musí být true, aby běžel Adobe path v kódu)
# DOCUMENT_PROCESSING_ENABLED=false
# Enable structured extraction (Extract JSON) – uses extra Adobe transactions
# DOCUMENT_EXTRACT_ENABLED=false
# Adobe PDF Services credentials (required when provider=adobe)
# Stejné hodnoty lze použít i jako PDF_SERVICES_CLIENT_ID / PDF_SERVICES_CLIENT_SECRET (Adobe sample projekty).
# ADOBE_PDF_SERVICES_CLIENT_ID=
# ADOBE_PDF_SERVICES_CLIENT_SECRET=
# Region: ew1 / eu1 / eu (EU), ue1 (US east), nebo vynechat pro výchozí pdf-services.adobe.io
# ADOBE_PDF_SERVICES_REGION=ew1
# OCR jazyk (Adobe podporuje omezený seznam; výchozí en-US). Např. cs-CZ jen pokud API přijme.
# ADOBE_OCR_LANG=en-US

# --- Cron API (Vercel Cron) ---
# Tajný náhodný řetězec – vygeneruj si (např. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# a nastav stejně na Vercelu. Vercel často posílá Authorization: Bearer <CRON_SECRET> automaticky.
# CRON_SECRET=
#
# Kalendářní připomenutí (cron /api/cron/event-reminders): push přes FCM + e-mail přes Resend na user_profiles.email.
# Sloupec events.reminder_notified_at (migrace packages/db/migrations/add_event_reminder_notified_at.sql).
# EVENT_REMINDER_EMAIL=0   # vypne jen e-mail; push zůstane, pokud je FCM_SERVICE_ACCOUNT_JSON
