NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Produkce: kanonická URL aplikace (pro e-maily, pozvánky). Např. https://www.aidvisora.cz
NEXT_PUBLIC_APP_URL=https://www.aidvisora.cz

# OpenAI (Responses API) – https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenAI Prompt Builder – prompt IDs (from Playground / prompt builder). Optional; leave empty to disable per feature.
OPENAI_PROMPT_CLIENT_SUMMARY_ID=
OPENAI_PROMPT_CLIENT_OPPORTUNITIES_ID=
OPENAI_PROMPT_NEXT_BEST_ACTION_ID=
OPENAI_PROMPT_PRE_MEETING_BRIEFING_ID=
OPENAI_PROMPT_POST_MEETING_FOLLOWUP_ID=
OPENAI_PROMPT_TEAM_SUMMARY_ID=
# Optional: default version for all prompts (e.g. "1"). Or set per-prompt: OPENAI_PROMPT_CLIENT_SUMMARY_VERSION=1
# OPENAI_PROMPT_VERSION=

# Resend (e-mail) – get your API key at https://resend.com
# Replace re_xxxxxxxxx with your real API key from Resend dashboard
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# Google Calendar (OAuth2) – https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web application), add redirect URIs:
#   http://localhost:3000/api/calendar/oauth/callback
#   https://<your-domain>/api/calendar/oauth/callback
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Šifrování tokenů integrací (AES-256): 32 B v hex (64 znaků) nebo alespoň 32 znaků UTF-8.
# Vygenerovat např.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATIONS_ENCRYPTION_KEY=

# --- POUZE PRO LOCALHOST (ODSTRANIT / NEVYPLŇOVAT V PRODUKCI) ---
# Umožní /api/contracts/* bez přihlášení; NODE_ENV=development + tento klíč musí být nastaven.
# Hodnota = UUID uživatele z tabulky auth.users (nebo člena s membership). Před deployem smazat.
# DEV_CONTRACTS_USER_ID=
