NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Produkce: kanonická URL aplikace (pro e-maily, pozvánky). Např. https://www.aidvisora.cz
NEXT_PUBLIC_APP_URL=https://www.aidvisora.cz

# Úvodní stránka: URL embed videa (např. YouTube: https://www.youtube.com/embed/VIDEO_ID)
# NEXT_PUBLIC_LANDING_DEMO_VIDEO_URL=

# OpenAI (Responses API) – https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenAI Prompt Builder – prompt IDs (from Playground / prompt builder). Optional; leave empty to disable per feature.
OPENAI_PROMPT_CLIENT_SUMMARY_ID=
OPENAI_PROMPT_CLIENT_OPPORTUNITIES_ID=
OPENAI_PROMPT_NEXT_BEST_ACTION_ID=
OPENAI_PROMPT_PRE_MEETING_BRIEFING_ID=
OPENAI_PROMPT_POST_MEETING_FOLLOWUP_ID=
OPENAI_PROMPT_TEAM_SUMMARY_ID=
# Optional: default version for all prompts (e.g. "1"). Or set per-prompt: OPENAI_PROMPT_CLIENT_SUMMARY_VERSION=1
# OPENAI_PROMPT_VERSION=

# Resend (e-mail) – get your API key at https://resend.com
# Replace re_xxxxxxxxx with your real API key from Resend dashboard
RESEND_API_KEY=re_xxxxxxxxx
# Lokálně: onboarding@resend.dev. Produkce (ověřená doména): např. noreply@aidvisora.cz nebo Aidvisora <noreply@aidvisora.cz>
RESEND_FROM_EMAIL=onboarding@resend.dev
# Volitelně: doména pro personalizovaný From (musí být ověřená v Resend), např. aidvisora.cz
# RESEND_FROM_DOMAIN=aidvisora.cz
# Volitelně: globální fallback Reply-To, pokud není e-mail v profilu / účtu
# RESEND_REPLY_TO=

# Google OAuth2 (sdílený pro Calendar, Drive, Gmail) – https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web application).
# Authorized redirect URIs:
#   http://localhost:3000/api/integrations/google-calendar/callback
#   http://localhost:3000/api/integrations/google-drive/callback
#   http://localhost:3000/api/integrations/gmail/callback
#   https://www.aidvisora.cz/api/integrations/google-calendar/callback
#   https://www.aidvisora.cz/api/integrations/google-drive/callback
#   https://www.aidvisora.cz/api/integrations/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Zpětná kompatibilita (starší kód čte tyto; nastavte na stejné hodnoty jako výše):
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Šifrování tokenů integrací (AES-256): 32 B v hex (64 znaků) nebo alespoň 32 znaků UTF-8.
# Vygenerovat např.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATIONS_ENCRYPTION_KEY=

# Google Maps / Places API – autocomplete adres.
# Vytvořte API key v Google Cloud Console s omezením na Places API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Capacitor – dev server pro mobilní build (volitelné)
# cap:dev = localhost:3000 (prohlížeč / stejný počítač)
# cap:dev:android = 10.0.2.2:3000 (lokální Android emulátor na tomto PC)
# Vzdálený telefon / cloud emulátor: použij v apps/web příkaz „pnpm cap:dev:remote“
#   (nastaví URL na IP tohoto počítače). Telefon a PC musí být ve stejné síti.
# Cloud / vzdálené zařízení (bez přístupu do sítě): spusť ngrok (ngrok http 3000),
#   pak v apps/web: pnpm cap:dev:ngrok (načte URL z ngrok a spustí cap sync).
# CAPACITOR_SERVER_URL=http://192.168.1.100:3000

# --- POUZE LOKÁLNÍ VÝVOJ (NIKDY NEVYPLŇOVAT NA VERCELU / V PRODUKCI) ---
# NEXT_PUBLIC_SKIP_AUTH=true  → dashboard bez přihlášení (např. pnpm dev:demo)
# DEV_CONTRACTS_USER_ID=uuid  → bypass auth pro API při NODE_ENV=development (UUID z auth.users)
# Na Vercelu produkce se tyto proměnné ignorují (kód kontroluje VERCEL_ENV).
# NEXT_PUBLIC_SKIP_AUTH=false
# DEV_CONTRACTS_USER_ID=

# --- Sentry (error tracking) – https://sentry.io ---
# DSN z projektu (Next.js). Pro klienta musí být veřejná varianta:
NEXT_PUBLIC_SENTRY_DSN=
# Volitelně stejný DSN pro server (jinak se použije NEXT_PUBLIC_SENTRY_DSN):
# SENTRY_DSN=
# Volitelně: environment tag v Sentry na klientu (preview vs production); jinak NODE_ENV
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Build / CI – upload source maps (token z sentry.io → Auth tokens, scope project:releases)
# SENTRY_AUTH_TOKEN=
# Příklad (tvůj Sentry projekt): org aidvisora, project javascript-nextjs
# SENTRY_ORG=aidvisora
# SENTRY_PROJECT=javascript-nextjs

# --- Stripe (předplatné workspace) – https://dashboard.stripe.com ---
# Publishable: veřejný klíč (pk_live_… / pk_test_…). Secret a webhook secret jen na serveru.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring Price ID z Products (price_…), ne částka v kódu
STRIPE_PRICE_ID=

# --- Cron API (Vercel Cron) ---
# Tajný náhodný řetězec – vygeneruj si (např. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# a nastav stejně na Vercelu. Vercel často posílá Authorization: Bearer <CRON_SECRET> automaticky.
# CRON_SECRET=
